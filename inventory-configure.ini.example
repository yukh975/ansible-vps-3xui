# =============================================================================
# inventory-configure.ini — ЭТАП 2 (порт 275, yukh)
# Скопировать в inventory-configure.ini и заполнить
# =============================================================================

[new_vps]
vps1 ansible_host=YOUR_SERVER_IP

[new_vps:vars]
ansible_user=yukh
ansible_port=275
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_ssh_extra_args='-o StrictHostKeyChecking=no'
