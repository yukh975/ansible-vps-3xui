# Ansible
*.retry
.ansible/

# Inventory с реальными IP (шаблон *.example коммитится)
inventory.ini

# Секреты и файлы с сервера (ключи, сертификаты, БД, пароли)
roles/bootstrap/files/*
!roles/bootstrap/files/.gitkeep
group_vars/new_vps.yml

# Переменные конкретных хостов (шаблоны *.example коммитятся)
host_vars/*.yml
!host_vars/*.yml.example
