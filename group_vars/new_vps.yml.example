---
# =============================================================================
# group_vars/new_vps.yml — variables for all new nodes
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
hostname: "vps1.example.com"        # Server FQDN (used for hostname and ACME certificate)

# ── SSH ───────────────────────────────────────────────────────────────────────
ssh_port: 275

# ── Main user ─────────────────────────────────────────────────────────────────
# Username that Ansible uses in stage 2 (after hardening).
# Must match one of the keys in the users dict below.
deploy_user: myuser

# ── Users ─────────────────────────────────────────────────────────────────────
#
# Single dict of all users to create on the server.
# Each user (except root) is created via the user module.
#
# Passwords are stored as SHA-512 hashes.
# Generate a hash on the control node:
#   openssl passwd -6 'YOUR_PASSWORD'
# or:
#   python3 -c "from passlib.hash import sha512_crypt; print(sha512_crypt.hash('YOUR_PASSWORD'))"
#
# Recommended: encrypt this file with ansible-vault:
#   ansible-vault encrypt group_vars/new_vps.yml
#
# Flags:
#   groups          — list of Linux groups (default [])
#   shell           — shell (default /bin/bash)
#   password        — SHA-512 password hash
#   sudo_nopasswd   — create /etc/sudoers.d/<user> with NOPASSWD (default false)
#   ssh_public_keys — list of public SSH keys (cat ~/.ssh/id_ed25519.pub)
#
users:
  myuser:
    groups: ["sudo"]
    shell: /bin/bash
    password: "$6$REPLACE$WITH_PASSWORD_HASH"
    sudo_nopasswd: true
    ssh_public_keys:
      - "ssh-ed25519 REPLACE_WITH_YOUR_PUBLIC_KEY ansible"
      # - "ssh-ed25519 SECOND_KEY personal-laptop"   # optional
  root:
    password: "$6$REPLACE$WITH_PASSWORD_HASH"

# ── Certificates (ACME via Caddy) ─────────────────────────────────────────────
# Caddy automatically obtains and renews the certificate via Let's Encrypt.
#
acme_email: "admin@example.com"

# ── 3x-ui ─────────────────────────────────────────────────────────────────────
install_3xui: true                  # false = skip 3x-ui installation
xui_version: ""                     # empty = latest; or "2.3.11"
xui_db_src: "files/x-ui.db"
xui_db_dest: "/etc/x-ui/x-ui.db"

# ── Caddy ─────────────────────────────────────────────────────────────────────
# How it works:
#   Caddy listens on port 443, obtains TLS certificate via ACME (HTTP-01, port 80).
#   xui_panel_path  → x-ui management panel (localhost:xui_panel_port)
#   xray_ws_path    → xray WebSocket (localhost:xray_port, VPN traffic)
#   everything else → redirect to caddy_fallback_url (camouflage site)

# External camouflage site — where Caddy redirects non-VPN traffic
caddy_fallback_url: "https://example.com"

# Secret path for the x-ui management panel (starts with /).
# The * wildcard at the end is added automatically.
xui_panel_path: "/your-secret-panel-path"

# x-ui panel port (localhost only, proxied through Caddy)
xui_panel_port: 54321

# Secret path for xray WebSocket connections (starts with /).
# The * wildcard at the end is added automatically.
xray_ws_path: "/your-secret-path"

# Port on which xray listens for WebSocket connections (localhost only)
xray_port: 10000

# ── Packages ──────────────────────────────────────────────────────────────────
# Additional packages (optional).
# Mandatory packages (iptables, iptables-persistent, ipset, ipset-persistent,
# netfilter-persistent, sqlite3) are installed automatically — no need to duplicate.
extra_packages:
  - sudo
  - curl
  - wget
  - unzip
  - ca-certificates
  - gnupg
  - mc
  - micro
  - dnsutils       # nslookup
  - telnet
  - traceroute

# ── sysctl ────────────────────────────────────────────────────────────────────
# Kernel parameters. Applied via sysctl --system and written to sysctl_dest
# for persistence across reboots.
sysctl_dest: "/etc/sysctl.d/99-custom.conf"
sysctl_settings:
  # TCP hardening
  net.ipv4.tcp_syncookies: 1
  net.ipv4.tcp_fin_timeout: 15
  net.ipv4.tcp_keepalive_time: 300
  net.ipv4.tcp_keepalive_probes: 5
  net.ipv4.tcp_keepalive_intvl: 15
  # Spoofing protection
  net.ipv4.conf.all.rp_filter: 1
  net.ipv4.conf.default.rp_filter: 1
  # No packet forwarding (not a router)
  net.ipv4.ip_forward: 0
  net.ipv6.conf.all.forwarding: 0
  # Ignore broadcast ping
  net.ipv4.icmp_echo_ignore_broadcasts: 1
  # Connection queue
  net.core.somaxconn: 1024
  net.ipv4.tcp_max_syn_backlog: 2048
  # BBR — required for 3x-ui (value without = sign)
  net.core.default_qdisc: fq
  net.ipv4.tcp_congestion_control: bbr

# ── iptables ──────────────────────────────────────────────────────────────────
# Rules are generated from templates/iptables_v4.j2 / iptables_v6.j2.
# SSH port and ipset set are substituted automatically.
#
# allowed_tcp_ports — additional TCP ports open to everyone
# allowed_udp_ports — additional UDP ports open to everyone
iptables_rules_v4_dest: "/etc/iptables/rules.v4"
iptables_rules_v6_dest: "/etc/iptables/rules.v6"

allowed_tcp_ports:
  - 80    # HTTP (Caddy ACME HTTP-01 challenge)
  - 443   # HTTPS (xray inbounds)

allowed_udp_ports: []
  # - 51820  # WireGuard (example)

# ── ipset ─────────────────────────────────────────────────────────────────────
# Ansible creates a hash:ip set named ipset_set_name and adds each address
# from ipset_hosts via ipset add.
# If the list is empty — the ipset block is skipped (set is still created empty).
ipset_set_name: "allowed_hosts"     # set name (used in iptables rules)
ipset_hosts:
  - "1.2.3.4"
  - "5.6.7.8"
  # - "another IP"
