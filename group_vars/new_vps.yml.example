---
# =============================================================================
# group_vars/new_vps.yml — переменные для всех новых нод
# =============================================================================

# ── Сервер ───────────────────────────────────────────────────────────────────
hostname: "vps1.example.com"        # FQDN сервера
domain: "example.com"               # домен для сертификатов

# ── SSH ───────────────────────────────────────────────────────────────────────
ssh_port: 275

# ── Основной пользователь ────────────────────────────────────────────────────
# Имя пользователя, от которого Ansible работает на этапе 2 (после hardening).
# Должен совпадать с одним из ключей в словаре users ниже.
deploy_user: yukh

# ── Пользователи ─────────────────────────────────────────────────────────────
#
# Единый словарь всех пользователей, создаваемых на сервере.
# Каждый пользователь (кроме root) создаётся через модуль user.
#
# Пароли хранятся в виде хэша SHA-512.
# Сгенерировать хэш на control node:
#   openssl passwd -6 'ВАШ_ПАРОЛЬ'
# или:
#   python3 -c "from passlib.hash import sha512_crypt; print(sha512_crypt.hash('ВАШ_ПАРОЛЬ'))"
#
# Рекомендуется зашифровать этот файл через ansible-vault:
#   ansible-vault encrypt group_vars/new_vps.yml
#
# Флаги:
#   groups             — список групп Linux (по умолчанию [])
#   shell              — оболочка (по умолчанию /bin/bash)
#   password           — хэш пароля SHA-512
#   sudo_nopasswd      — создать /etc/sudoers.d/<user> с NOPASSWD (по умолчанию false)
#   has_authorized_keys — скопировать files/<user>/authorized_keys (по умолчанию false)
#   has_bashrc         — скопировать files/<user>/.bashrc (по умолчанию false)
#
users:
  yukh:
    groups: ["sudo", "root"]
    shell: /bin/bash
    password: "$6$ЗАМЕНИТЕ$НА_ХЭШ_ПАРОЛЯ"
    sudo_nopasswd: true
    ssh_public_keys:
      - "ssh-ed25519 ЗАМЕНИТЕ_НА_ВАШ_ПУБЛИЧНЫЙ_КЛЮЧ ansible"
  ca:
    groups: []
    shell: /bin/bash
    password: "$6$ЗАМЕНИТЕ$НА_ХЭШ_ПАРОЛЯ"
    sudo_nopasswd: true
    ssh_public_keys:
      - "ssh-ed25519 ЗАМЕНИТЕ_НА_ВАШ_ПУБЛИЧНЫЙ_КЛЮЧ ansible"
  root:
    password: "$6$ЗАМЕНИТЕ$НА_ХЭШ_ПАРОЛЯ"

# ── Сертификаты (ACME через Caddy) ───────────────────────────────────────────
# Caddy автоматически получает и обновляет сертификат через Let's Encrypt.
# Скрипт cert-sync ежедневно копирует сертификаты из хранилища Caddy
# в certs_dest_dir и перезапускает x-ui при изменении.
#
# acme_email  — обязательно, используется при регистрации в Let's Encrypt
# certs_dest_dir — куда копируются сертификаты для x-ui (должно совпадать с x-ui.db)
acme_email: "admin@example.com"
certs_dest_dir: "/etc/ssl/{{ domain }}"

# ── 3x-ui ────────────────────────────────────────────────────────────────────
install_3xui: true                  # false = пропустить установку 3x-ui
xui_version: ""                     # пусто = latest; или "2.3.11"
xui_db_src: "files/x-ui.db"
xui_db_dest: "/etc/x-ui/x-ui.db"

# ── Caddy ────────────────────────────────────────────────────────────────────
install_caddy: true                 # false = пропустить установку Caddy
# URL куда Caddy проксирует входящие HTTPS-запросы (3x-ui слушает локально)
caddy_redirect_url: "127.0.0.1:2053"
# HTTPS-порт Caddy. По умолчанию 8443, чтобы не конфликтовать с 3x-ui на 443.
# ACME (Let's Encrypt) использует HTTP-01 challenge через порт 80.
# Если 443 свободен — можно поставить 443 и убрать его из allowed_tcp_ports для 3x-ui.
caddy_https_port: 8443

# ── Пакеты ───────────────────────────────────────────────────────────────────
extra_packages:
  - sudo
  - iptables
  - iptables-persistent
  - ipset
  - netfilter-persistent
  - curl
  - wget
  - sqlite3
  - unzip
  - ca-certificates
  - gnupg
  - mc
  - micro
  - dnsutils       # nslookup
  - telnet
  - traceroute

# ── sysctl ────────────────────────────────────────────────────────────────────
# Параметры ядра. Ansible применяет каждый через модуль sysctl
# и записывает в sysctl_dest (персистентно через sysctl --system).
sysctl_dest: "/etc/sysctl.d/99-custom.conf"
sysctl_settings:
  # TCP hardening
  net.ipv4.tcp_syncookies: 1
  net.ipv4.tcp_fin_timeout: 15
  net.ipv4.tcp_keepalive_time: 300
  net.ipv4.tcp_keepalive_probes: 5
  net.ipv4.tcp_keepalive_intvl: 15
  # Защита от spoofing
  net.ipv4.conf.all.rp_filter: 1
  net.ipv4.conf.default.rp_filter: 1
  # Не форвардить пакеты (не роутер)
  net.ipv4.ip_forward: 0
  net.ipv6.conf.all.forwarding: 0
  # Игнорировать broadcast ping
  net.ipv4.icmp_echo_ignore_broadcasts: 1
  # Очередь соединений
  net.core.somaxconn: 1024
  net.ipv4.tcp_max_syn_backlog: 2048

# ── iptables ──────────────────────────────────────────────────────────────────
# Правила генерируются из шаблона templates/iptables_v4.j2 / iptables_v6.j2.
# Правила для SSH-порта и ipset-сета подставляются автоматически.
#
# allowed_tcp_ports — дополнительные TCP-порты открытые для всех
# allowed_udp_ports — дополнительные UDP-порты открытые для всех
iptables_rules_v4_dest: "/etc/iptables/rules.v4"
iptables_rules_v6_dest: "/etc/iptables/rules.v6"

allowed_tcp_ports:
  - 80    # HTTP (Caddy ACME HTTP-01 challenge + редирект)
  - 443   # HTTPS (3x-ui инбаунды)
  - 8443  # HTTPS (Caddy reverse proxy, см. caddy_https_port)

allowed_udp_ports: []
  # - 51820  # WireGuard (пример)

# ── ipset ────────────────────────────────────────────────────────────────────
# Ansible создаст set типа hash:ip с именем ipset_set_name и добавит
# каждый адрес из ipset_hosts через ipset add.
# Если список пуст — блок ipset пропускается.
ipset_set_name: "allowed_hosts"     # имя set'а (используется в iptables-правилах)
ipset_hosts:
  - "1.2.3.4"
  - "5.6.7.8"
  # - "ещё IP"
