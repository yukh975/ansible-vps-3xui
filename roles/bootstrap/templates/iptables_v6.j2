# /etc/iptables/rules.v6 — managed by Ansible, do not edit manually
# Generated from templates/iptables_v6.j2

*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Loopback
-A INPUT -i lo -j ACCEPT

# Established and related connections
-A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# ICMPv6 (required for proper IPv6 operation)
-A INPUT -p ipv6-icmp -j ACCEPT

# SSH
-A INPUT -p tcp --dport {{ ssh_port }} -j ACCEPT

# Additional TCP ports
{% for port in allowed_tcp_ports | default([]) %}
-A INPUT -p tcp --dport {{ port }} -j ACCEPT
{% endfor %}

# Additional UDP ports
{% for port in allowed_udp_ports | default([]) %}
-A INPUT -p udp --dport {{ port }} -j ACCEPT
{% endfor %}

COMMIT
