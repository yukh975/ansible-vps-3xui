# /etc/ssh/sshd_config — managed by Ansible, do not edit manually

Port {{ ssh_port }}
AddressFamily any
ListenAddress 0.0.0.0
ListenAddress ::

# Authentication
PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys

# Misc
UsePAM yes
X11Forwarding no
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server

# Timeouts
ClientAliveInterval 120
ClientAliveCountMax 3
LoginGraceTime 30

# Hardening
MaxAuthTries 3
MaxSessions 5
AllowTcpForwarding no
AllowAgentForwarding no
