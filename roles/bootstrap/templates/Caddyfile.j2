# /etc/caddy/Caddyfile — управляется Ansible, не редактировать вручную
# Сгенерировано из templates/Caddyfile.j2

{
    # Email для уведомлений Let's Encrypt об истечении сертификата
    email {{ acme_email }}
}

# ACME: Caddy получает сертификат для домена через HTTP-01 challenge (порт 80).
# Сертификат затем синхронизируется в certs_dest_dir для использования x-ray.
{{ domain }} {
    redir {{ caddy_fallback_url }}{uri} permanent
}

# Fallback-трафик от x-ray (не-VPN) — редирект на сайт-камуфляж
http://127.0.0.1:{{ caddy_listen_port | default(4443) }} {
    redir {{ caddy_fallback_url }}{uri} permanent
}
