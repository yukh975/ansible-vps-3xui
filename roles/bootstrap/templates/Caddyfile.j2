# /etc/caddy/Caddyfile — управляется Ansible, не редактировать вручную
# Сгенерировано из templates/Caddyfile.j2

:443 {
    tls {{ certs.base_dir }}/{{ domain }}.crt {{ certs.base_dir }}/{{ domain }}.key

    reverse_proxy {{ caddy_redirect_url }}
}

:80 {
    redir https://{host}{uri} permanent
}
