# /etc/caddy/Caddyfile — managed by Ansible, do not edit manually
# Generated from templates/Caddyfile.j2

{
    # Email for Let's Encrypt expiry notifications
    email {{ acme_email }}
    # debug  # Uncomment for debugging. Disable after debugging!
}

{{ hostname }} {
    # log {
    #     output stderr
    #     level DEBUG  # Uncomment for debugging. Disable after debugging!
    # }

    route {
        # x-ui management panel (secret URL, proxied to localhost)
        @panel path {{ xui_panel_path }}*
        reverse_proxy @panel localhost:{{ xui_panel_port }} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }

        # WebSocket → xray (VPN traffic via secret path)
        @vless path {{ xray_ws_path }}*
        reverse_proxy @vless localhost:{{ xray_port }} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }

        # Everything else — redirect to camouflage site
        redir {{ caddy_fallback_url }}{uri} permanent
    }
}
