# /etc/caddy/Caddyfile — управляется Ansible, не редактировать вручную
# Сгенерировано из templates/Caddyfile.j2

{
    # Email для уведомлений Let's Encrypt об истечении сертификата
    email {{ acme_email }}
    # debug  # Раскомментировать для отладки. Отключить после завершения отладки!
}

{{ hostname }} {
    # log {
    #     output stderr
    #     level DEBUG  # Раскомментировать для отладки. Отключить после завершения отладки!
    # }

    route {
        # Панель управления x-ui (секретный URL, проксируется на localhost)
        @panel path {{ xui_panel_path }}*
        reverse_proxy @panel localhost:{{ xui_panel_port }} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }

        # WebSocket → xray (VPN-трафик по секретному пути)
        @vless path {{ xray_ws_path }}*
        reverse_proxy @vless localhost:{{ xray_port }} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }

        # Всё остальное — редирект на сайт-камуфляж
        redir {{ caddy_fallback_url }}{uri} permanent
    }
}
