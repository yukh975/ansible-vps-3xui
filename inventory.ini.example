# =============================================================================
# inventory.ini.example — пример, скопировать в inventory.ini и заполнить
# =============================================================================

[new_vps]
vps1 ansible_host=1.2.3.4

[new_vps:vars]
ansible_user=root
ansible_port=22
ansible_ssh_extra_args='-o StrictHostKeyChecking=no'

# Запуск: ansible-playbook -i inventory.ini site.yml --ask-pass
